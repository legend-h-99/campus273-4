# Database
# ضع رابط قاعدة بيانات Neon/PostgreSQL هنا محليًا أو داخل Vercel Environment Variables
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# NextAuth v5
# أنشئ قيمة قوية بالأمر: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-secret"
AUTH_URL="http://localhost:3000"

# Optional AI keys used by the project
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
